generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  MARKETING_DIRECTOR
  MARKETING_MANAGER
  CONTENT_TEAM
  DESIGN_TEAM
  VIDEO_TEAM
  SALES_TEAM
  B2B_TEAM
  INTERN
  VIEW_ONLY
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  BLOCKED
  DONE
}

enum CampaignType {
  DIGITAL
  OFFLINE
  BRAND
  PERFORMANCE
  WHATSAPP
  SMS
  EMAIL
  COLLEGE_VISIT
  B2B
  EVENT
}

enum CampaignStatus {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ContentStatus {
  IDEA
  WRITING
  DESIGN
  APPROVAL
  PUBLISHED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  DEMO
  NEGOTIATION
  WON
  LOST
}

enum ApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

model Workspace {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]
  projects    Project[]
  campaigns   Campaign[]
  vendors     Vendor[]
  budgets     Budget[]
  files       FileAsset[]
  reports     Report[]
  automations Automation[]
}

model User {
  id            String        @id @default(cuid())
  workspaceId   String?
  name          String
  email         String        @unique
  image         String?
  role          Role          @default(VIEW_ONLY)
  department    String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  workspace     Workspace?    @relation(fields: [workspaceId], references: [id])
  assignedTasks Task[]        @relation("AssignedTasks")
  createdTasks  Task[]        @relation("CreatedTasks")
  ownedCampaigns Campaign[]   @relation("CampaignOwner")
  leads         Lead[]        @relation("LeadOwner")
  comments      Comment[]
  activities    ActivityLog[] @relation("ActorActivities")
}

model Project {
  id          String      @id @default(cuid())
  workspaceId String
  name        String
  objective   String
  status      String      @default("Active")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  workspace   Workspace   @relation(fields: [workspaceId], references: [id])
  tasks       Task[]
  campaigns   Campaign[]
  milestones  Milestone[]
  files       FileAsset[]
}

model Milestone {
  id        String    @id @default(cuid())
  projectId String
  name      String
  dueDate   DateTime?
  status    String    @default("Open")
  project   Project   @relation(fields: [projectId], references: [id])
}

model Sprint {
  id          String    @id @default(cuid())
  name        String
  cadence     String
  goal        String
  capacity    Int
  velocity    Int       @default(0)
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tasks       Task[]
}

model Task {
  id          String      @id @default(cuid())
  title       String
  description String?
  priority    Priority    @default(MEDIUM)
  status      TaskStatus  @default(TODO)
  department  String
  dueDate     DateTime?
  timeTracked Int         @default(0)
  recurring   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  assigneeId  String?
  creatorId   String?
  projectId   String?
  campaignId  String?
  sprintId    String?
  assignee    User?       @relation("AssignedTasks", fields: [assigneeId], references: [id])
  creator     User?       @relation("CreatedTasks", fields: [creatorId], references: [id])
  project     Project?    @relation(fields: [projectId], references: [id])
  campaign    Campaign?   @relation(fields: [campaignId], references: [id])
  sprint      Sprint?     @relation(fields: [sprintId], references: [id])
  checklist   ChecklistItem[]
  comments    Comment[]
  dependencies TaskDependency[] @relation("TaskDependencies")
  blockedBy    TaskDependency[] @relation("TaskBlockedBy")
  files       FileAsset[]
  tags        Tag[]       @relation("TaskTags")
}

model TaskDependency {
  id        String @id @default(cuid())
  taskId    String
  blocksId  String
  task      Task   @relation("TaskDependencies", fields: [taskId], references: [id])
  blocks    Task   @relation("TaskBlockedBy", fields: [blocksId], references: [id])
}

model ChecklistItem {
  id        String  @id @default(cuid())
  taskId    String
  label     String
  completed Boolean @default(false)
  task      Task    @relation(fields: [taskId], references: [id])
}

model Campaign {
  id          String         @id @default(cuid())
  workspaceId String?
  projectId   String?
  ownerId     String
  title       String
  objective   String
  audience    String
  type        CampaignType
  status      CampaignStatus @default(PLANNING)
  budget      Decimal        @db.Decimal(12, 2)
  spent       Decimal        @default(0) @db.Decimal(12, 2)
  expectedRoi Decimal        @default(0) @db.Decimal(8, 2)
  actualRoi   Decimal        @default(0) @db.Decimal(8, 2)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workspace   Workspace?     @relation(fields: [workspaceId], references: [id])
  project     Project?       @relation(fields: [projectId], references: [id])
  owner       User           @relation("CampaignOwner", fields: [ownerId], references: [id])
  tasks       Task[]
  content     ContentItem[]
  leads       Lead[]
  expenses    Expense[]
  files       FileAsset[]
}

model ContentItem {
  id          String        @id @default(cuid())
  campaignId  String?
  channel     String
  title       String
  status      ContentStatus @default(IDEA)
  publishAt   DateTime?
  caption     String?
  hashtags    String[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  campaign    Campaign?     @relation(fields: [campaignId], references: [id])
  files       FileAsset[]
}

model Vendor {
  id                String        @id @default(cuid())
  workspaceId       String
  name              String
  company           String
  category          String
  contactPerson     String
  phone             String
  email             String
  gst               String?
  pan               String?
  upi               String?
  bankDetails       Json?
  address           String?
  services          String[]
  rating            Int           @default(0)
  paymentTerms      String?
  outstandingAmount Decimal       @default(0) @db.Decimal(12, 2)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  workspace         Workspace     @relation(fields: [workspaceId], references: [id])
  purchaseOrders    PurchaseOrder[]
  expenses          Expense[]
  files             FileAsset[]
}

model PurchaseOrder {
  id             String         @id @default(cuid())
  vendorId       String
  poNumber       String         @unique
  status         ApprovalStatus @default(DRAFT)
  paymentStatus  String         @default("Pending")
  deliveryStatus String         @default("Open")
  gstAmount      Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal        @db.Decimal(12, 2)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  vendor         Vendor         @relation(fields: [vendorId], references: [id])
  items          PurchaseOrderItem[]
  files          FileAsset[]
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  name            String
  quantity        Int
  amount          Decimal       @db.Decimal(12, 2)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
}

model Budget {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  period      String
  category    String
  amount      Decimal   @db.Decimal(12, 2)
  spent       Decimal   @default(0) @db.Decimal(12, 2)
  forecast    Decimal   @default(0) @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Expense {
  id          String    @id @default(cuid())
  campaignId  String?
  vendorId    String?
  category    String
  description String
  amount      Decimal   @db.Decimal(12, 2)
  spentAt     DateTime
  createdAt   DateTime  @default(now())
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  vendor      Vendor?   @relation(fields: [vendorId], references: [id])
}

model Lead {
  id          String     @id @default(cuid())
  campaignId  String?
  ownerId     String?
  source      String
  company     String?
  name        String
  email       String?
  phone       String?
  status      LeadStatus @default(NEW)
  followUpAt  DateTime?
  notes       String?
  convertedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  campaign    Campaign?  @relation(fields: [campaignId], references: [id])
  owner       User?      @relation("LeadOwner", fields: [ownerId], references: [id])
  meetings    Meeting[]
  files       FileAsset[]
}

model Meeting {
  id        String   @id @default(cuid())
  leadId    String?
  title     String
  startsAt  DateTime
  notes     String?
  summary   String?
  createdAt DateTime @default(now())
  lead      Lead?    @relation(fields: [leadId], references: [id])
}

model Automation {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  trigger     String
  action      String
  status      String    @default("Active")
  lastRunAt   DateTime?
  logs        Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model FileAsset {
  id              String          @id @default(cuid())
  workspaceId      String?
  projectId        String?
  campaignId       String?
  taskId           String?
  vendorId         String?
  leadId           String?
  contentItemId    String?
  purchaseOrderId  String?
  name            String
  bucket          String
  path            String
  mimeType        String
  size            Int
  version         Int             @default(1)
  createdAt       DateTime        @default(now())
  workspace       Workspace?      @relation(fields: [workspaceId], references: [id])
  project         Project?        @relation(fields: [projectId], references: [id])
  campaign        Campaign?       @relation(fields: [campaignId], references: [id])
  task            Task?           @relation(fields: [taskId], references: [id])
  vendor          Vendor?         @relation(fields: [vendorId], references: [id])
  lead            Lead?           @relation(fields: [leadId], references: [id])
  contentItem     ContentItem?    @relation(fields: [contentItemId], references: [id])
  purchaseOrder   PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id])
}

model Report {
  id          String    @id @default(cuid())
  workspaceId String
  title       String
  type        String
  payload     Json
  exportedUrl String?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model AnalyticsSnapshot {
  id        String   @id @default(cuid())
  scope     String
  scopeId   String?
  metric    String
  value     Decimal  @db.Decimal(14, 4)
  capturedAt DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String?
  authorId  String
  body      String
  mentions  String[]
  createdAt DateTime @default(now())
  task      Task?    @relation(fields: [taskId], references: [id])
  author    User     @relation(fields: [authorId], references: [id])
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String
  tasks Task[] @relation("TaskTags")
}

model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  message    String
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("ActorActivities", fields: [actorId], references: [id])
}
